# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo (or repo for traffic data)
GITHUB_TOKEN=ghp_your_token_here

# Optional: Limit number of repositories to process (useful for testing)
# If not set, processes all repositories
MAX_REPOS=5

# Optional: Force re-fetching data even if files already exist
# Set to 'true' to ignore existing files in steps 2, 3, 4
# FORCE_REFETCH=true